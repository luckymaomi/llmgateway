LLMGATEWAY_PROFILE=production
LLMGATEWAY_HTTP_ADDRESS=127.0.0.1:8080
LLMGATEWAY_DATABASE_URL_FILE=C:\ProgramData\LLMGateway\secrets\database-url
LLMGATEWAY_DATABASE_MIGRATE_ON_START=false
LLMGATEWAY_VALKEY_ADDRESS=127.0.0.1:6379
LLMGATEWAY_VALKEY_PASSWORD_FILE=C:\ProgramData\LLMGateway\secrets\valkey-password
LLMGATEWAY_MASTER_KEYS_FILE=C:\ProgramData\LLMGateway\secrets\master-keys
LLMGATEWAY_ACTIVE_MASTER_KEY_VERSION=1
LLMGATEWAY_SESSION_PEPPER_FILE=C:\ProgramData\LLMGateway\secrets\session-pepper
LLMGATEWAY_API_KEY_PEPPER_FILE=C:\ProgramData\LLMGateway\secrets\api-key-pepper
LLMGATEWAY_COORDINATION_KEY_HASH_SECRET_FILE=C:\ProgramData\LLMGateway\secrets\coordination-secret
LLMGATEWAY_COOKIE_SECURE=true
