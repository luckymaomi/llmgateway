# Copy this file outside the repository and replace every example path/value.
LLMGATEWAY_GATEWAY_IMAGE=registry.example.test/llmgateway@sha256:replace_with_release_digest
LLMGATEWAY_POSTGRES_IMAGE=postgres@sha256:replace_with_postgres_18_4_digest
LLMGATEWAY_VALKEY_IMAGE=valkey/valkey@sha256:replace_with_valkey_9_1_0_digest
LLMGATEWAY_CADDY_IMAGE=caddy@sha256:replace_with_caddy_2_10_2_digest
LLMGATEWAY_ACTIVE_MASTER_KEY_VERSION=1
LLMGATEWAY_SITE_ADDRESS=gateway.example.test
LLMGATEWAY_ACME_EMAIL=operations@example.test
LLMGATEWAY_POSTGRES_DB=llmgateway
LLMGATEWAY_POSTGRES_USER=llmgateway
LLMGATEWAY_POSTGRES_PASSWORD_FILE=/etc/llmgateway/secrets/postgres-password
LLMGATEWAY_DATABASE_URL_FILE=/etc/llmgateway/secrets/database-url
LLMGATEWAY_VALKEY_PASSWORD_FILE=/etc/llmgateway/secrets/valkey-password
LLMGATEWAY_VALKEY_ACL_FILE=/etc/llmgateway/secrets/valkey-acl
LLMGATEWAY_MASTER_KEYS_FILE=/etc/llmgateway/secrets/master-keys
LLMGATEWAY_SESSION_PEPPER_FILE=/etc/llmgateway/secrets/session-pepper
LLMGATEWAY_API_KEY_PEPPER_FILE=/etc/llmgateway/secrets/api-key-pepper
LLMGATEWAY_COORDINATION_KEY_HASH_SECRET_FILE=/etc/llmgateway/secrets/coordination-secret
