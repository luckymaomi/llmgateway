# Keep this file and all Restic control files outside /etc/llmgateway and the staging root.
LLMGATEWAY_BACKUP_MODE=production
LLMGATEWAY_RESTIC_IMAGE=restic/restic@sha256:136600b6ff6843d61d355f7f71f460a166429f35de6fd11b568fece3c9a4d510
LLMGATEWAY_RESTIC_REPOSITORY_FILE=/etc/llmgateway-backup/repository
LLMGATEWAY_RESTIC_PASSWORD_FILE=/etc/llmgateway-backup/password
# Production currently supports only an S3 repository and requires this root-only credentials file.
LLMGATEWAY_RESTIC_AWS_CREDENTIALS_FILE=/etc/llmgateway-backup/aws-credentials
# LLMGATEWAY_RESTIC_AWS_CONFIG_FILE=/etc/llmgateway-backup/aws-config
# Production repository files must contain one remote S3 Restic URL. Isolated acceptance
# uses LLMGATEWAY_BACKUP_MODE=acceptance, repository local:/repository, and an explicit local directory.
# LLMGATEWAY_RESTIC_LOCAL_REPOSITORY_DIRECTORY=/var/lib/llmgateway-backup-acceptance/repository
LLMGATEWAY_DEPLOYMENT_ENVIRONMENT_FILE=/etc/llmgateway/deployment.env
LLMGATEWAY_CONFIGURATION_DIRECTORY=/etc/llmgateway
LLMGATEWAY_BACKUP_STAGING_ROOT=/var/lib/llmgateway-backup
LLMGATEWAY_BACKUP_LAST_SUCCESS_MARKER_FILE=/var/lib/llmgateway-backup/last-success
LLMGATEWAY_RESTIC_CHECK_SUBSET=5%
