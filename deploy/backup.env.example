# Keep this file and the Restic password outside /etc/llmgateway so they are not included in the snapshot.
LLMGATEWAY_RESTIC_IMAGE=restic/restic@sha256:136600b6ff6843d61d355f7f71f460a166429f35de6fd11b568fece3c9a4d510
LLMGATEWAY_RESTIC_REPOSITORY_FILE=/etc/llmgateway-backup/repository
LLMGATEWAY_RESTIC_PASSWORD_FILE=/etc/llmgateway-backup/password
# Set these file sources when the selected remote backend uses AWS-compatible credentials.
# LLMGATEWAY_RESTIC_AWS_CREDENTIALS_FILE=/etc/llmgateway-backup/aws-credentials
# LLMGATEWAY_RESTIC_AWS_CONFIG_FILE=/etc/llmgateway-backup/aws-config
LLMGATEWAY_DEPLOYMENT_ENVIRONMENT_FILE=/etc/llmgateway/production.env
LLMGATEWAY_CONFIGURATION_DIRECTORY=/etc/llmgateway
LLMGATEWAY_BACKUP_STAGING_ROOT=/var/lib/llmgateway-backup
LLMGATEWAY_RESTIC_CHECK_SUBSET=5%
LLMGATEWAY_RUNTIME_SECRET_GID=65532
